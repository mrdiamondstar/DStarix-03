# Copy this file to `.env.local` and set your real values.
# Also add these in the Vercel project's Environment Variables.

# Google Analytics 4 Measurement ID (e.g. G-XXXXXXXXXX)
NEXT_PUBLIC_GA_ID=

# Web3Forms access key — from https://web3forms.com dashboard (public key)
NEXT_PUBLIC_WEB3FORMS_ACCESS_KEY=
